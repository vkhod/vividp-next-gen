FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /conversion ./cmd/conversion

FROM alpine:3.20
# Ghostscript for PDFs, ImageMagick for images
RUN apk add --no-cache ca-certificates tzdata ghostscript imagemagick
COPY --from=builder /conversion /conversion
EXPOSE 8081
ENTRYPOINT ["/conversion"]

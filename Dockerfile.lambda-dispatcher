FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /lambda-dispatcher ./cmd/lambda-dispatcher

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /lambda-dispatcher /lambda-dispatcher
ENTRYPOINT ["/lambda-dispatcher"]

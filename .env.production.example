# Copy to /opt/vividp/.env on the Hetzner server and fill in real values.
# docker compose -f docker-compose.prod.yml --env-file .env up -d

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# MinIO
MINIO_ROOT_USER=vividp
MINIO_ROOT_PASSWORD=change_me_strong_password

# GitHub repository (lowercase), e.g. your-org/vividp-next-gen
GITHUB_REPOSITORY=your-org/vividp-next-gen

# Anthropic API key for recognition service
ANTHROPIC_API_KEY=sk-ant-...

# Admin UI auth (optional — leave ADMIN_PASSWORD empty to disable auth in dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_SESSION_SECRET=change_me_random_32char_string

# Lambda dispatcher — comma-separated STATUS:url pairs (leave empty until Lambdas are deployed)
LAMBDA_DISPATCH=

# Optional: set to "debug" for verbose logs
LOG_LEVEL=info

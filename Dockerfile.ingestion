FROM golang:1.23-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /ingestion ./cmd/ingestion

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /ingestion /ingestion
EXPOSE 8080
ENTRYPOINT ["/ingestion"]

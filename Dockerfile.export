FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /export ./cmd/export

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /export /export
ENTRYPOINT ["/export"]
